# ============================================================
# LLM Distributed Query System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ── HMAC Tokenization ──
# Shared secret for cross-database blind matching.
# All workers MUST use the same salt. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SALT=<generate-with-python-secrets-token-hex-32>

# ── Database Passwords (development defaults) ──
MYSQL_ROOT_PASSWORD=root
PG_PASSWORD=pw

# ── LLM Configuration (optional — falls back to rule-based parser) ──
# DeepSeek API (OpenAI-compatible)
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=<your-deepseek-api-key>
LLM_MODEL=deepseek-chat

# Alternative: local Ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# ── API Authentication (optional — leave empty to disable) ──
# API_TOKEN=<your-shared-api-token>
